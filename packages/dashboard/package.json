{
  "name": "@local/pi-dashboard",
  "version": "0.0.1",
  "description": "Real-time web dashboard for Pi showing orchestrator and sub-agent state",
  "type": "module",
  "private": true,
  "keywords": ["pi-package"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "watch": "bun run build.ts --watch",
    "build:frontend": "cd frontend && bun run build",
    "build:all": "bun run build && bun run build:frontend",
    "test": "vitest --run"
  },
  "dependencies": {
    "@orpc/server": "^1.14.3",
    "@local/pi-subagents": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*"
  }
}
