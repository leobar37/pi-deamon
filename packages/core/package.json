{
  "name": "@local/pi-core",
  "version": "0.0.1",
  "description": "Session backend, Lion orchestration, and bundled Pi extensions",
  "type": "module",
  "private": true,
  "keywords": ["pi-package"],
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./sdk": "./dist/sdk/index.js",
    "./contract": {
      "types": "./src/api/contract.ts",
      "default": "./dist/api/contract.js"
    },
    "./extensions/*": {
      "types": "./src/extensions/*/index.ts",
      "default": "./dist/*.js"
    },
    "./shared/*": "./src/shared/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "build": "bun run build.ts",
    "watch": "bun run build.ts --watch",
    "test": "vitest --run"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@local/pi-dashboard": "workspace:*",
    "@local/pi-logger": "workspace:*",
    "@orpc/contract": "^1.14.3",
    "@orpc/server": "^1.14.3",
    "diff": "^8.0.2",
    "esbuild": "^0.28.0",
    "typebox": "^1.1.24",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "^0.79.2"
  },
  "pi": {
    "extensions": ["./dist"]
  }
}
